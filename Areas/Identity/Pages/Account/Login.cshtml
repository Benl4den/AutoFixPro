@page
@model LoginModel
@{
    ViewData["Title"] = "Admin Login";
    Layout = "/Areas/Identity/Pages/_Layout.cshtml";
}
<style>
    /* Fix for the white/yellow background on Autofill */
    input:-webkit-autofill,
    input:-webkit-autofill:hover,
    input:-webkit-autofill:focus,
    input:-webkit-autofill:active {
        /* Use an inset shadow to fill the background with black */
        -webkit-box-shadow: 0 0 0 1000px #000 inset !important;
        /* Force the text color to stay white */
        -webkit-text-fill-color: white !important;
        /* Ensure the border doesn't disappear */
        border: 2px solid #004085 !important;
        transition: background-color 5000s ease-in-out 0s;
    }

    /* Optional: Transition to prevent the "flash" of white when the page loads */
    input {
        transition: background-color 5000s ease-in-out 0s;
    }
</style>


<div class="identity-card shadow-lg">
    <div class="text-center mb-4">
        <h4 class="fw-bold text-white">Welcome Back</h4>
        <p class="text-muted small">Please sign in to access the Admin Dashboard</p>
    </div>

    <form id="account" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

        <div class="form-floating mb-3">
            <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
            <label asp-for="Input.Email" class="text-muted">Email Address</label>
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>

        <div class="form-floating mb-3">
            <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
            <label asp-for="Input.Password" class="text-muted">Password</label>
            <span asp-validation-for="Input.Password" class="text-danger"></span>
        </div>

        <div class="checkbox mb-4 ps-1">
            <label asp-for="Input.RememberMe" class="form-label text-muted small">
                <input class="form-check-input me-2" asp-for="Input.RememberMe" />
                @Html.DisplayNameFor(m => m.Input.RememberMe)
            </label>
        </div>

        <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary shadow-sm py-3 fw-bold">
            <i class="bi bi-box-arrow-in-right me-2"></i>Log In
        </button>

        <div class="text-center mt-4">
            <p class="mb-1">
                <a id="forgot-password" asp-page="./ForgotPassword" class="text-decoration-none small text-primary">Forgot your password?</a>
            </p>
        </div>
    </form>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}