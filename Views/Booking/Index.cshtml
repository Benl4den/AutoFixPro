@model IEnumerable<AutoFix_Pro.Models.Appointment>

@{
    ViewData["Title"] = "Admin Dashboard - Bookings";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-white fw-bold">Manage Appointments</h1>
        <span class="badge bg-primary px-3 py-2">Total: @Model.Count()</span>
    </div>

    <div class="card bg-dark border-secondary shadow-lg">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-dark table-hover mb-0">
                    <thead class="table-primary text-dark">
                        <tr>
                            <th>Customer Name</th>
                            <th>Service</th>
                            <th>Plate Number</th>
                            <th>Date & Time</th>
                            <th>Status</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="align-middle">@item.CustomerName</td>
                                <td class="align-middle">@item.ServiceType</td>
                                <td class="align-middle"><code class="text-info fw-bold">@item.VehiclePlate</code></td>
                                <td class="align-middle text-muted">@item.BookingDate.ToString("MMM dd, yyyy hh:mm tt")</td>
                                <td class="align-middle">
                                    <span class="badge @(item.Status == "Pending" ? "bg-warning" : "bg-success") text-dark">
                                        @item.Status
                                    </span>
                                </td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-outline-info me-1">Details</button>
                                    <button class="btn btn-sm btn-outline-success">Complete</button>
                                </td>
                            </tr>
                        }

                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">No appointments found in the database.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>