@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<ul class="navbar-nav align-items-center">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item dropdown admin-dropdown">
            @* The "Trigger" - Updated to Blue Accent Wrench Style *@
            <a class="nav-link dropdown-toggle d-flex align-items-center p-0 border-0" href="#" id="adminMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                @if (User.IsInRole("SuperAdmin"))
                {
                    <div class="super-admin-badge-blue">
                        <i class="bi bi-wrench-adjustable"></i>
                        <span class="badge-text">SUPER ADMIN</span>
                    </div>
                }
                else
                {
                    <div class="super-admin-badge-blue bg-primary">
                        @* Standard Admin uses primary blue *@
                        <i class="bi bi-person-fill"></i>
                        <span class="badge-text">ADMIN</span>
                    </div>
                }
            </a>

            @* The "Pop-up" Menu *@
            <ul class="dropdown-menu dropdown-menu-end custom-admin-menu animate slideIn" aria-labelledby="adminMenu">
                <div class="px-3 py-2 border-bottom border-secondary mb-2">
                    <small class="text-white-50 d-block">Account Management</small>
                    <span class="fw-bold text-truncate d-inline-block text-white" style="max-width: 150px;">@User.Identity?.Name</span>
                </div>

                <li>
                    <a class="dropdown-item py-2" asp-area="Identity" asp-page="/Account/Manage/Index">
                        <i class="bi bi-gear-fill me-2 text-primary"></i> Profile Settings
                    </a>
                </li>

                @if (User.IsInRole("SuperAdmin"))
                {
                    <li>
                        <a class="dropdown-item py-2" asp-area="Identity" asp-page="/Account/Register">
                            <i class="bi bi-person-plus-fill me-2 text-success"></i> Add Admin
                        </a>
                    </li>
                }

                <li><hr class="dropdown-divider border-secondary"></li>

                <li>
                    <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                        <button type="submit" class="dropdown-item py-2 text-danger">
                            <i class="bi bi-box-arrow-right me-2"></i> Logout System
                        </button>
                    </form>
                </li>
            </ul>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="login-button-outline" asp-area="Identity" asp-page="/Account/Login">
                <i class="bi bi-box-arrow-in-right"></i>
                <span>LOG IN</span>
            </a>
        </li>
    }
</ul>