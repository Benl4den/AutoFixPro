@model AutoFix_Pro.Models.ServiceTicket

@{
    ViewData["Title"] = "Delete Service";
}

<div class="container mt-4">
    <h1 class="text-danger">Delete Service</h1>
    <h3>Are you sure you want to delete this?</h3>
    <hr />

    <div class="card shadow-sm border-danger col-md-8">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-4">Service Name</dt>
                <dd class="col-sm-8 text-primary fw-bold">@Html.DisplayFor(model => model.ServiceName)</dd>

                <dt class="col-sm-4">Category</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Category)</dd>

                <dt class="col-sm-4">Price</dt>
                <dd class="col-sm-8 text-success">₱@Html.DisplayFor(model => model.Price)</dd>
            </dl>

            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <div class="mt-4">
                    <button type="submit" class="btn btn-danger px-4">Confirm Delete</button>
                    <a asp-action="Index" class="btn btn-secondary mx-2">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>