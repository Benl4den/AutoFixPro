@model AutoFix_Pro.Models.ServiceTicket

@{
    ViewData["Title"] = "Add New Service";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            @* 1. Changed card to bg-dark and border-secondary *@
            <div class="card shadow-lg border-secondary bg-dark text-white">
                <div class="card-header bg-primary text-white py-3 border-secondary">
                    <h4 class="mb-0">Create New Auto Service</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row">
                            <div class="col-md-7">
                                <div class="mb-3">
                                    <label asp-for="ServiceName" class="form-label fw-bold text-white-50"></label>
                                    @* 2. Applied dark input classes *@
                                    <input asp-for="ServiceName" class="form-control bg-dark border-secondary text-white" placeholder="e.g. Full Synthetic Oil Change" />
                                    <span asp-validation-for="ServiceName" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Category" class="form-label fw-bold text-white-50"></label>
                                    @* 3. Applied dark select classes *@
                                    <select asp-for="Category" class="form-select bg-dark border-secondary text-white">
                                        <option value="">-- Select Category --</option>
                                        <option value="Maintenance">Maintenance</option>
                                        <option value="Repair">Repair</option>
                                        <option value="Diagnostics">Diagnostics</option>
                                        <option value="Detailing">Detailing</option>
                                    </select>
                                    <span asp-validation-for="Category" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Price" class="form-label fw-bold text-white-50"></label>
                                    <div class="input-group">
                                        @* 4. Styled the input group text *@
                                        <span class="input-group-text bg-secondary border-secondary text-white">₱</span>
                                        <input asp-for="Price" class="form-control bg-dark border-secondary text-white" type="number" step="0.01" />
                                    </div>
                                    <span asp-validation-for="Price" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-md-5 text-center">
                                <label class="form-label fw-bold text-white-50">Image Preview</label>
                                @* 5. Changed preview background to dark *@
                                <div class="border border-secondary rounded bg-black d-flex align-items-center justify-content-center" style="height: 180px; overflow: hidden;">
                                    <img id="imgPreview" src="https://placehold.co/600x400/212529/6c757d?text=Paste+URL" class="img-fluid" style="object-fit: cover; height: 100%; width: 100%;" />
                                </div>
                                <div class="mt-3">
                                    <label asp-for="ImageUrl" class="form-label fw-bold text-white-50">Image URL</label>
                                    <input asp-for="ImageUrl" id="urlInput" class="form-control form-control-sm bg-dark border-secondary text-white" placeholder="https://..." />
                                    <span asp-validation-for="ImageUrl" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3 mt-3">
                            <label asp-for="Description" class="form-label fw-bold text-white-50"></label>
                            @* 6. Applied dark textarea classes *@
                            <textarea asp-for="Description" class="form-control bg-dark border-secondary text-white" rows="3" placeholder="Describe the service details..."></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <hr class="border-secondary" />
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-light">Back to List</a>
                            <button type="submit" class="btn btn-primary px-5 shadow-sm">Save Service</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Script to update the preview image when the URL changes
        document.getElementById('urlInput').addEventListener('input', function() {
            const url = this.value;
            const preview = document.getElementById('imgPreview');
            if (url) {
                preview.src = url;
            } else {
                preview.src = "https://placehold.co/600x400?text=Paste+URL";
            }
        });
    </script>
}