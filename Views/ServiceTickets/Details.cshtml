@model AutoFix_Pro.Models.ServiceTicket

@{
    ViewData["Title"] = "Service Details";
}

<div class="container py-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-primary">Services</a></li>
            <li class="breadcrumb-item active text-white" aria-current="page">@Model.ServiceName</li>
        </ol>
    </nav>

    <div class="row g-5">
        <div class="col-md-6">
            <img src="@Model.ImageUrl" class="img-fluid rounded-4 shadow-lg border border-secondary" alt="@Model.ServiceName">
        </div>
        <div class="col-md-6">
            <span class="badge bg-primary mb-2">@Model.Category</span>
            <h1 class="display-4 fw-bold mb-3">@Model.ServiceName</h1>
            <h2 class="text-success mb-4">₱@Model.Price.ToString("N0")</h2>
            <p class="lead text-muted mb-5">@Model.Description</p>

            <div class="d-grid gap-2 d-md-flex">
                @* UPDATED: Changed from <button> to <a> with Tag Helpers *@
                <a asp-controller="Booking"
                   asp-action="Create"
                   asp-route-serviceType="@Model.ServiceName"
                   class="btn btn-primary btn-lg px-5 shadow fw-bold">
                    Book This Service
                </a>

                @if (User.Identity.IsAuthenticated)
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-warning btn-lg">
                        <i class="bi bi-pencil-square me-1"></i> Edit Service
                    </a>
                }
            </div>
        </div>
    </div>
</div>