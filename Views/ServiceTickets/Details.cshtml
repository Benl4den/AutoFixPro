@model AutoFix_Pro.Models.ServiceTicket

@{
    ViewData["Title"] = Model.ServiceName + " - Details";
}

<div class="container py-5 mt-4">
    <nav aria-label="breadcrumb" class="mb-5">
        <ol class="breadcrumb" style="font-size: 0.85rem; letter-spacing: 0.5px;">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-primary text-decoration-none fw-bold text-uppercase">Services</a></li>
            <li class="breadcrumb-item active text-white-50 text-uppercase" aria-current="page">@Model.ServiceName</li>
        </ol>
    </nav>

    <div class="row g-lg-5 align-items-center">
        <div class="col-lg-6 mb-4 mb-lg-0">
            <div class="position-relative">
                <img src="@Model.ImageUrl" class="img-fluid rounded-5 shadow-lg border border-secondary"
                     alt="@Model.ServiceName" style="width: 100%; height: 500px; object-fit: cover; filter: brightness(0.9);">
                
                <div class="position-absolute top-0 start-0 m-4">
                    <span class="badge bg-primary px-3 py-2 rounded-pill shadow-lg fw-bold">
                        <i class="bi bi-gear-fill me-1"></i> @Model.Category
                    </span>
                </div>
            </div>
        </div>

        <div class="col-lg-6 ps-lg-5">
            <div class="service-content">
                <h1 class="display-3 fw-bold text-white mb-2">@Model.ServiceName</h1>
                
                <div class="d-flex align-items-center mb-4">
                    <h2 class="text-success fw-bold mb-0" style="font-size: 2.5rem;">₱@Model.Price.ToString("N0")</h2>
                    <span class="ms-3 text-muted small border-start ps-3 border-secondary">Estimated Starting Price</span>
                </div>

                <div class="mb-5">
                    <h6 class="text-primary text-uppercase fw-bold mb-3" style="letter-spacing: 2px;">Service Overview</h6>
                    <p class="lead text-muted" style="line-height: 1.8; font-size: 1.15rem;">
                        @Model.Description
                    </p>
                </div>

                <div class="row g-3 mb-5 border-top border-bottom border-secondary py-4">
                    <div class="col-6">
                        <div class="d-flex align-items-center small text-white">
                            <i class="bi bi-shield-check text-primary me-2"></i> Quality Guaranteed
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="d-flex align-items-center small text-white">
                            <i class="bi bi-person-badge text-primary me-2"></i> Expert Mechanics
                        </div>
                    </div>
                    <div class="col-6 mt-3">
                        <div class="d-flex align-items-center small text-white">
                            <i class="bi bi-clock-history text-primary me-2"></i> Same Day Service
                        </div>
                    </div>
                    <div class="col-6 mt-3">
                        <div class="d-flex align-items-center small text-white">
                            <i class="bi bi-tools text-primary me-2"></i> Genuine Parts
                        </div>
                    </div>
                </div>

                <div class="d-grid gap-3 d-md-flex">
                    @* THIS IS THE AUTOMATIC LINK *@
                    <a asp-controller="Booking"
                           asp-action="Create"
                           asp-route-serviceType="@Model.ServiceName"
                           class="btn btn-primary btn-lg px-5 py-3 rounded-pill shadow-lg fw-bold text-uppercase border-0"
                           style="background: linear-gradient(135deg, #0d6efd 0%, #0046b3 100%); transition: 0.3s ease;">
                        <i class="bi bi-calendar-check me-2"></i> Book This Service
                    </a>

                    @if (User.Identity.IsAuthenticated && (User.IsInRole("Admin") || User.IsInRole("SuperAdmin")))
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-warning btn-lg px-4 rounded-pill d-flex align-items-center justify-content-center">
                            <i class="bi bi-pencil-square me-2"></i> Edit
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .img-fluid:hover {
        filter: brightness(1);
        transition: all 0.5s ease;
    }

    .breadcrumb-item a:hover {
        color: #fff !important;
        text-decoration: underline !important;
    }

    .btn-primary:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(13, 110, 253, 0.4) !important;
    }
</style>