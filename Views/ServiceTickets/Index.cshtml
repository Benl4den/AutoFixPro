@model IEnumerable<AutoFix_Pro.Models.ServiceTicket>

@{
    ViewData["Title"] = "Service Inventory";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold text-primary"><i class="bi bi-list-task"></i> Service Inventory</h1>
            <p class="text-muted">Manage your automotive service offerings and pricing</p>
        </div>
        <a asp-action="Create" class="btn btn-primary shadow-sm px-4">
            <i class="bi bi-plus-lg"></i> Add New Service
        </a>
    </div>

    <div class="card shadow-sm border-0 mb-4 bg-dark text-white">
        <div class="card-body">
            <form asp-controller="ServiceTickets" asp-action="Index" method="get">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="input-group">
                            <span class="input-group-text bg-secondary border-0 text-white">
                                <i class="bi bi-search"></i>
                            </span>
                            <input type="text" name="searchString" class="form-control bg-dark border-secondary text-white"
                                   placeholder="Search services..." />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <select name="category" class="form-select bg-dark border-secondary text-white">
                            <option value="">All Categories</option>
                            <option value="Maintenance">Maintenance</option>
                            <option value="Repair">Repair</option>
                            <option value="Diagnostics">Diagnostics</option>
                            <option value="Detailing">Detailing</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-secondary w-100">Filter</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="table-responsive shadow-lg rounded-3">
        <table class="table table-hover align-middle border-0 mb-0" style="background: #1e1e1e; color: white;">
            <thead class="table-dark">
                <tr>
                    <th class="ps-4">Service Name</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted">
                            No services found matching your criteria.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr style="border-bottom: 1px solid #333;">
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <img src="@item.ImageUrl" class="rounded-2 me-3" style="width: 45px; height: 45px; object-fit: cover; border: 1px solid #444;">
                                    <span class="fw-bold text-white">@item.ServiceName</span>
                                </div>
                            </td>
                            <td><span class="badge rounded-pill bg-secondary text-light">@item.Category</span></td>
                            <td class="text-success fw-bold">₱@item.Price.ToString("N2")</td>
                            <td class="text-center">
                                <div class="btn-group" role="group">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning border-0" title="Edit">
                                        <i class="bi bi-pencil-square fs-5"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info border-0" title="View">
                                        <i class="bi bi-eye fs-5"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger border-0" title="Delete">
                                        <i class="bi bi-trash fs-5"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    .table-hover tbody tr:hover {
        background-color: #252525 !important;
        transition: background-color 0.2s ease;
    }

    .form-control::placeholder {
        color: #6c757d;
    }
</style>