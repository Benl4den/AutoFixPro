@model IEnumerable<AutoFix_Pro.Models.ServiceTicket>

@{
    ViewData["Title"] = "Service Inventory";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-end mb-5">
        <div>
            <h1 class="display-5 fw-bold text-white">
                <i class="bi bi-tools text-primary me-2 spinning-gear"></i>Services <span class="text-primary">Offered</span>
            </h1>
            <p class="text-muted mb-0">Explore our professional automotive service offerings</p>
        </div>
        
        @if (User.Identity.IsAuthenticated && (User.IsInRole("Admin") || User.IsInRole("SuperAdmin")))
        {
            <a asp-action="Create" class="btn btn-primary rounded-pill shadow px-4 py-2 fw-bold">
                <i class="bi bi-plus-lg me-1"></i> ADD NEW SERVICE
            </a>
        }
    </div>

    <div class="card shadow-lg border-secondary mb-5 bg-dark rounded-4 overflow-hidden" style="border: 1px solid rgba(255,255,255,0.1) !important;">
        <div class="card-body p-4">
            <form asp-controller="ServiceTickets" asp-action="Index" method="get">
                <div class="row g-3 align-items-center">
                    <div class="col-md-5">
                        <div class="input-group">
                            <span class="input-group-text bg-black border-secondary text-muted">
                                <i class="bi bi-search"></i>
                            </span>
                            <input type="text" name="searchString"
                                   class="form-control bg-black border-secondary text-white"
                                   placeholder="Search services (e.g. Engine Scan)..." />
                        </div>
                    </div>

                    <div class="col-md-4">
                        <select name="category" class="form-select bg-black border-secondary text-muted">
                            <option value="">All Categories</option>
                            <option value="Maintenance">Maintenance</option>
                            <option value="Repair">Repair</option>
                            <option value="Diagnostics">Diagnostics</option>
                            <option value="Detailing">Detailing</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <button type="submit" class="btn btn-primary w-100 fw-bold rounded-3 shadow-sm">
                            <i class="bi bi-filter-right me-1"></i> FILTER RESULTS
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card bg-dark border-secondary shadow-lg rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0 align-middle">
                <thead class="bg-black text-uppercase small" style="letter-spacing: 1px;">
                    <tr>
                        <th class="py-4 ps-4">Service Details</th>
                        <th class="py-4">Category</th>
                        <th class="py-4 text-success">Starting Price</th>
                        <th class="py-4 text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <i class="bi bi-info-circle me-2"></i> No services found matching your criteria.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                                <td class="ps-4 py-4">
                                    <div class="d-flex align-items-center">
                                        <div class="position-relative">
                                            <img src="@item.ImageUrl" class="rounded-3 me-3 shadow-sm"
                                                 style="width: 55px; height: 55px; object-fit: cover; border: 1px solid #444;">
                                        </div>
                                        <div>
                                            <h6 class="mb-0 fw-bold text-white">@item.ServiceName</h6>
                                            <span class="text-muted x-small">Certified Pro Service</span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge rounded-pill bg-secondary bg-opacity-25 text-light border border-secondary px-3 py-2">
                                        @item.Category
                                    </span>
                                </td>
                                <td>
                                    <h6 class="mb-0 fw-bold text-success">₱@item.Price.ToString("N2")</h6>
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2 align-items-center">
                                        
                                        @* HIDE BOOK BUTTON FOR ADMINS AND SUPERADMINS *@
                                        @if (!(User.Identity.IsAuthenticated && (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))))
                                        {
                                            <a asp-action="Details" asp-route-id="@item.Id"
                                                   class="btn btn-sm btn-outline-primary rounded-pill px-3 py-1 fw-bold">
                                                <i class="bi bi-calendar-plus me-1"></i> BOOK
                                            </a>
                                        }

                                        @if (User.Identity.IsAuthenticated && (User.IsInRole("Admin") || User.IsInRole("SuperAdmin")))
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-link text-warning p-0" title="Edit">
                                                <i class="bi bi-pencil-square fs-5"></i>
                                            </a>
                                            <div class="vr mx-1 opacity-25" style="height: 20px;"></div>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-link text-danger p-0" title="Delete">
                                                <i class="bi bi-trash fs-5"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .bg-black {
        background-color: #000 !important;
    }
    
    .x-small {
        font-size: 0.75rem;
    }

    .table-hover tbody tr:hover {
        background-color: rgba(0, 123, 255, 0.03) !important;
        transition: all 0.3s ease;
    }

    .form-control:focus, .form-select:focus {
        background-color: #000 !important;
        border-color: #0d6efd !important;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
        color: white;
    }

    .form-control::placeholder {
        color: #6c757d;
    }
</style>