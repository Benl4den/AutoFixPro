@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityUser>

@{
    ViewData["Title"] = "User Management";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4 text-white">
        <h2 class="fw-bold"><i class="bi bi-people-fill me-2 text-primary"></i>Staff Management</h2>
        <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary shadow rounded-pill px-4">
            <i class="bi bi-person-plus-fill me-1"></i> Register New Admin
        </a>
    </div>

    <div class="card bg-dark border-dark-blue shadow-lg rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0 align-middle">
                <thead class="bg-dark-blue">
                    <tr>
                        <th class="py-3 px-4 text-uppercase small" style="letter-spacing: 1px;">Email / Username</th>
                        <th class="py-3 px-4 text-center text-uppercase small" style="letter-spacing: 1px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="px-4 py-3">
                                <div class="fw-bold text-white">@user.Email</div>
                                @if (user.Email == User.Identity.Name)
                                {
                                    <span class="badge bg-info text-dark x-small">You (SuperAdmin)</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (user.Email != User.Identity.Name)
                                {
                                    @* We use a button instead of a direct form submit to trigger the Nice UI *@
                                    <button type="button" 
                                            class="btn btn-outline-danger btn-sm rounded-pill px-3" 
                                            onclick="confirmStaffRemoval('@user.Email', '@user.Id')">
                                        <i class="bi bi-trash3 me-1"></i> Remove
                                    </button>

                                    @* Hidden form that the JavaScript will submit after confirmation *@
                                    <form id="delete-form-@user.Id" asp-action="DeleteUser" method="post" style="display:none;">
                                        <input type="hidden" name="userId" value="@user.Id" />
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .border-dark-blue { border: 1px solid rgba(0, 123, 255, 0.2) !important; }
    .bg-dark-blue { background-color: #000 !important; border-bottom: 1px solid #333; }
    .x-small { font-size: 0.7rem; }
    .table-hover tbody tr:hover {
        background-color: rgba(0, 123, 255, 0.05) !important;
        transition: all 0.3s ease;
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmStaffRemoval(userEmail, userId) {
            Swal.fire({
                title: '<i class="bi bi-person-x text-danger"></i> STAFF <span class="text-danger">MANAGEMENT</span>',
                html: `
                    <div class="text-center">
                        <h4 class="fw-bold text-white text-uppercase mb-3">Terminate Access?</h4>
                        <div class="bg-black border border-secondary rounded-3 p-3 mb-4 shadow-sm">
                            <p class="mb-1 text-muted small">Revoking credentials for:</p>
                            <h5 class="fw-bold text-danger mb-0">${userEmail}</h5>
                        </div>
                        <p class="text-white-50 small">This action will immediately remove this user from the system.</p>
                    </div>
                `,
                background: '#0d0d0d',
                color: '#ffffff',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#343a40',
                confirmButtonText: 'Yes, Remove Access',
                cancelButtonText: 'Cancel',
                customClass: {
                    popup: 'border border-secondary rounded-4 shadow-lg'
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    // Manually submit the hidden form for that specific user
                    document.getElementById('delete-form-' + userId).submit();
                }
            });
        }
    </script>
}